# Sample environment variables for local development
# Copy this to `backend/.env` and customize secrets before running

# Database (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=discovery_app
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/discovery_app

# FastAPI / App
SECRET_KEY=replace-this-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Claude / analysis (optional for local; required for analysis features)
# CLAUDE_API_KEY=<your-anthropic-api-key>

# Optional: email settings for real deployments
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Optional: LangSmith tracing (https://docs.langchain.com/langsmith/annotate-code)
# Set LANGSMITH_TRACING=true + LANGSMITH_API_KEY to send traces. Set project name so traces appear in LangSmith UI.
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=Discovery_app
# LANGSMITH_API_KEY=<your-key-from-smith-dot-langchain-dot-com>

# Note: Do NOT commit your real `backend/.env` with secrets.
