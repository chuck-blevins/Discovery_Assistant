# Sample environment variables for local development
# Copy this to `backend/.env` and customize secrets before running

# Database (Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=discovery_app
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/discovery_app

# FastAPI / App
SECRET_KEY=replace-this-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: email settings for real deployments
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Note: Do NOT commit your real `backend/.env` with secrets.
